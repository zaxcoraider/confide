# Confide — Ethereum Sepolia (11155111)
#
# Copy this file to .env.local and fill it in there.
# .env.local is gitignored; THIS file is not — never put a real key here.

# Deployer / proposer key. Use a throwaway testnet key only.
DEPLOYER_PRIVATE_KEY=0x

# Optional — defaults to a public Sepolia RPC if unset
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# The LIVE Sepolia deployment, prefilled so `npm run dev` works straight after a
# clone. These are public addresses; there is nothing secret here.
#
# `npm run phase1` also reuses the wrapper below rather than redeploying.
# Deploying your own? Replace all three. Note that `phase2` / `phase3` act as a
# Safe owner, so they need a Safe YOU own — not the one below.
NEXT_PUBLIC_CONFIDENTIAL_USDC=0x5cbe8c86e72c06e8c13ddbb7ab11c011f25fb30d
NEXT_PUBLIC_PAYROLL_MODULE=0xc508bd3aea398a1995280101f183dfeb89bba76b
NEXT_PUBLIC_SAFE_ADDRESS=0xb3BDc26Ae8E992Cb1BA793BfDc26CeF329bE5E0A
